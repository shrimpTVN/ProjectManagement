<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" prefHeight="68.0" prefWidth="1280.0" style="-fx-border-color: black; -fx-border-width: 0.5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="70.0" prefWidth="304.0">
            <children>
                <Circle fill="DODGERBLUE" radius="18.0" stroke="BLACK" strokeType="INSIDE">
                    <HBox.margin>
                        <Insets bottom="5.0" left="50.0" right="5.0" top="5.0" />
                    </HBox.margin>
                </Circle>
                <Label prefHeight="43.0" prefWidth="154.0" text="TickTask">
                    <font>
                        <Font name="Urbanist Bold" size="36.0" />
                    </font>
                </Label>
            </children>
        </HBox>
        <Region maxWidth="1.7976931348623157E308" prefHeight="65.0" prefWidth="786.0" />
        <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="63.0" prefWidth="186.0" spacing="30.0">
            <Label fx:id="notificationIcon" style="-fx-font-size: 18px;" text="🔔" />
            <Label fx:id="profileIcon" style="-fx-font-size: 20px;" text="👤" />
            <opaqueInsets>
                <Insets right="50.0" />
            </opaqueInsets>
        </HBox>
    </children>
</HBox>