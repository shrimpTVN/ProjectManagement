<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>


<?import javafx.scene.Cursor?>
<HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" prefHeight="68.0" prefWidth="1280.0"
      style="-fx-border-color: black; -fx-border-width: 0.5;" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.src.controllers.HeaderController">
    <children>
        <HBox fx:id="appLogo" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="70.0" prefWidth="304.0" onMouseClicked="#handleAppLogoClick">
            <children>
                <Circle fill="DODGERBLUE" radius="18.0" stroke="BLACK" strokeType="INSIDE">
                    <HBox.margin>
                        <Insets bottom="5.0" left="50.0" right="5.0" top="5.0"/>
                    </HBox.margin>
                </Circle>
                <Label  prefHeight="43.0" prefWidth="154.0" style="-fx-font-weight: bold;" styleClass="font-36"
                       text="TickTask"/>
            </children>
            <cursor>
                <Cursor fx:constant="HAND"/>
            </cursor>
        </HBox>
        <Region maxWidth="1.7976931348623157E308" prefHeight="65.0" prefWidth="786.0"/>
        <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="63.0" prefWidth="186.0" spacing="30.0">
            <children>
                <Label fx:id="notificationIcon" styleClass="font-20" text="🔔"/>
                <Label fx:id="profileIcon" styleClass="font-20" text="👤"/>
            </children>
            <opaqueInsets>
                <Insets right="50.0"/>
            </opaqueInsets>
        </HBox>
    </children>
</HBox>