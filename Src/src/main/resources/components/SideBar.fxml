<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="655.0" prefWidth="322.0" style="-fx-border-color: black; -fx-border-width: 0 0.2 0.2 0.2;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.SideBarController">
    <children>
        <HBox fx:id="forMeMenu" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="302.0">
            <children>
            <ImageView fitHeight="23.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../image/user.png" />
               </image>
            </ImageView>
                <Label maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="218.0" styleClass="font-20" text="For me">
               <padding>
                  <Insets left="10.0" />
               </padding></Label>
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" top="15.0" />
            </VBox.margin>
        </HBox>

        <HBox fx:id="myProjectMenu" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="25.0" prefWidth="278.0">
            <children>
            <ImageView fitHeight="26.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../image/down-arrow.png" />
               </image>
               <HBox.margin>
                  <Insets left="22.0" />
               </HBox.margin>
            </ImageView>
                <Label fx:id="myProjectLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="31.0" prefWidth="194.0" styleClass="font-20" text="My project" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets />
                    </HBox.margin>
               <padding>
                  <Insets left="10.0" />
               </padding>
                </Label>
                <Button fx:id="addProjectBtn" alignment="CENTER" contentDisplay="CENTER" graphicTextGap="3.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="27.0" prefWidth="44.0" styleClass="flat-btn" text="+" textAlignment="CENTER">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Button>
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </HBox>
      <HBox prefHeight="100.0" prefWidth="320.0" />
    </children>
    <cursor>
        <Cursor fx:constant="HAND" />
    </cursor>
</VBox>
