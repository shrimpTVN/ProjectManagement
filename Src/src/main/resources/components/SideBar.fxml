<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="655.0" prefWidth="322.0" style="-fx-border-color: black; -fx-border-width: 0.5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox fx:id="forMeMenu" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="302.0">
            <children>
                <Label alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="34.0" styleClass="font-20" text="👤" textAlignment="CENTER" />
                <Label maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="218.0" styleClass="font-20" text="For me" />
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" top="15.0" />
            </VBox.margin>
        </HBox>

        <HBox fx:id="myProjectMenu" maxWidth="1.7976931348623157E308" prefHeight="25.0" prefWidth="278.0">
            <children>
                <Label fx:id="myProjectLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="38.0" prefWidth="202.0" styleClass="font-20" text="&gt; My project" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin>
                </Label>
                <Button fx:id="addProjectBtn" alignment="CENTER" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="50.0" prefWidth="50.0" styleClass="flat-btn" text="+" textAlignment="CENTER">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Button>
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </HBox>

        <VBox fx:id="projectList" managed="true" maxWidth="1.7976931348623157E308" prefHeight="184.0" prefWidth="278.0" visible="true">
            <children>
                <HBox alignment="CENTER" prefHeight="30.0" prefWidth="278.0">
                    <children>
                        <TextField fx:id="searchProjectField" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="26.0" prefWidth="254.0" promptText="🔍    Find" styleClass="input-field, font-14" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </TextField>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="Recent">
                    <VBox.margin>
                        <Insets left="45.0" top="10.0" />
                    </VBox.margin>
                </Label>

                <Label maxWidth="1.7976931348623157E308" prefHeight="18.0" prefWidth="248.0" styleClass="font-14" text="Project A">
                    <VBox.margin>
                        <Insets left="45.0" top="5.0" />
                    </VBox.margin>
                </Label>

                <Label maxWidth="1.7976931348623157E308" styleClass="font-14" text="Project B">
                    <VBox.margin>
                        <Insets left="45.0" top="15.0" />
                    </VBox.margin>
                </Label>

                <Label maxWidth="1.7976931348623157E308" styleClass="font-14" text="Project C">
                    <VBox.margin>
                        <Insets left="45.0" top="15.0" />
                    </VBox.margin>
                </Label>
            </children>
            <VBox.margin>
                <Insets bottom="15.0" left="20.0" right="20.0" top="5.0" />
            </VBox.margin>
        </VBox>
    </children>
    <cursor>
        <Cursor fx:constant="HAND" />
    </cursor>
</VBox>
