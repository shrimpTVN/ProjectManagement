<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="655.0" prefWidth="322.0" style="-fx-border-color: black; -fx-border-width: 0.5;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.SideBarController">
    <children>
        <HBox fx:id="forMeMenu" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="302.0">
            <children>
                <Label alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="34.0" styleClass="font-20" text="👤" textAlignment="CENTER" />
                <Label maxWidth="1.7976931348623157E308" prefHeight="40.0" prefWidth="218.0" styleClass="font-20" text="For me" />
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" top="15.0" />
            </VBox.margin>
        </HBox>

        <HBox fx:id="myProjectMenu" maxWidth="1.7976931348623157E308" prefHeight="25.0" prefWidth="278.0">
            <children>
                <Label fx:id="myProjectLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="38.0" prefWidth="202.0" styleClass="font-20" text="&gt; My project" HBox.hgrow="ALWAYS">
                    <HBox.margin>
                        <Insets left="30.0" />
                    </HBox.margin>
                </Label>
                <Button fx:id="addProjectBtn" alignment="CENTER" contentDisplay="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="50.0" prefWidth="50.0" styleClass="flat-btn" text="+" textAlignment="CENTER">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Button>
            </children>
            <VBox.margin>
                <Insets left="20.0" right="20.0" />
            </VBox.margin>
        </HBox>
    </children>
    <cursor>
        <Cursor fx:constant="HAND" />
    </cursor>
</VBox>
