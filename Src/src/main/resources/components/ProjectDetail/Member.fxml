<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.MemberController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>
                <HBox fx:id="headerHBox" alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtUserName" prefHeight="30.0" prefWidth="200.0" promptText="Enter user name..." styleClass="input-field" />
                        <ComboBox fx:id="cbRole" prefHeight="30.0" prefWidth="150.0" promptText="Select Role" styleClass="input-field" />
                        <Button fx:id="btnAddUser" mnemonicParsing="false" prefHeight="30.0" prefWidth="80.0" style="-fx-border-width: 0.5;" styleClass="btn-action" text=" Add" textFill="#4896fe">
                     <graphic>
                        <ImageView fitHeight="15.0" fitWidth="13.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../image/plus.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font></Button>
                        <Region prefHeight="27.0" prefWidth="182.0" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnEditUser" mnemonicParsing="false" prefHeight="30.0" prefWidth="80.0" styleClass="btn-action" text="Edit" />
                        <Button fx:id="btnCancel" mnemonicParsing="false" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: grey; -fx-border-color: grey; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="btn-action" text="Cancel" textFill="WHITE" />
                    </children>
                </HBox>

                <TableView fx:id="memberTable" prefHeight="303.0" prefWidth="820.0" styleClass="custom-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                        <TableColumn fx:id="colRole" prefWidth="120.0" text="Role" />
                        <TableColumn fx:id="colDOB" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Date of Birth" />
                        <TableColumn fx:id="colPhone" prefWidth="130.0" text="Phone number" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Region maxWidth="1.7976931348623157E308" prefHeight="30.0" prefWidth="726.0" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnDeleteUser" mnemonicParsing="false" prefHeight="30.0" prefWidth="80.0" styleClass="btn-action" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
