<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" styleClass="member-root" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.MemberController">
    <children>
        <VBox spacing="12.0" styleClass="member-layout" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
            <padding>
                <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
            </padding>
            <children>
                <HBox fx:id="headerHBox" alignment="CENTER_LEFT" spacing="10.0" styleClass="member-toolbar">
                    <children>
                        <TextField fx:id="txtUserName" prefHeight="34.0" prefWidth="220.0" promptText="Enter user name..." styleClass="member-input" />
                        <ComboBox fx:id="cbRole" prefHeight="34.0" prefWidth="160.0" promptText="Select Role" styleClass="member-input" />
                        <Button fx:id="btnAddUser" mnemonicParsing="false" prefHeight="34.0" prefWidth="90.0" styleClass="member-btn-primary" text=" Add" textFill="#2563EB">
                            <graphic>
                                <ImageView fitHeight="15.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../image/plus.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnEditUser" mnemonicParsing="false" prefHeight="34.0" prefWidth="90.0" styleClass="member-btn" text="Edit" />
                        <Button fx:id="btnCancel" mnemonicParsing="false" prefHeight="34.0" prefWidth="90.0" styleClass="member-btn-cancel" text="Cancel" textFill="WHITE" />
                    </children>
                </HBox>

                <TableView fx:id="memberTable" prefHeight="303.0" prefWidth="820.0" styleClass="member-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="150.0" style="-fx-alignment: CENTER_LEFT;" text="Name" />
                        <TableColumn fx:id="colRole" prefWidth="120.0" style="-fx-alignment: CENTER_LEFT;" text="Role" />
                        <TableColumn fx:id="colDOB" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Date of Birth" />
                        <TableColumn fx:id="colPhone" prefWidth="130.0" style="-fx-alignment: CENTER_LEFT;" text="Phone number" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnDeleteUser" mnemonicParsing="false" prefHeight="34.0" prefWidth="90.0" styleClass="member-btn-danger" text="Delete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
