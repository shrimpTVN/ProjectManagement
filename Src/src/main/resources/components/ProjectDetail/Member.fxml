<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.MemberController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0"
              AnchorPane.topAnchor="15.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtUserName" prefWidth="200.0" promptText="Enter user name..."/>
                        <ComboBox fx:id="cbRole" prefWidth="150.0" promptText="Select Role"/>
                        <Button fx:id="btnAddUser" mnemonicParsing="false" prefHeight="26.0" prefWidth="80.0"
                                styleClass="btn-action" text="Add"/>
                        <Button fx:id="btnEditUser" mnemonicParsing="false" prefHeight="26.0" prefWidth="80.0"
                                styleClass="btn-action" text="Edit"/>
                    </children>
                </HBox>

                <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="150.0" text="Name"/>
                        <TableColumn fx:id="colRole" prefWidth="120.0" text="Role"/>
                        <TableColumn fx:id="colDOB" prefWidth="120.0" style="-fx-alignment: CENTER;"
                                     text="Date of Birth"/>
                        <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email"/>
                        <TableColumn fx:id="colPhone" prefWidth="130.0" text="Phone number"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>
