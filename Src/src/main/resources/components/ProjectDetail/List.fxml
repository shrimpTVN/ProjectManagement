<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="549.6" styleClass="list-root" stylesheets="@../../css/ListDetailProject.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.ListController">
   <children>
      <VBox spacing="12.0" styleClass="list-layout" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="12.0">
         <padding>
            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="list-toolbar">
               <children>

                  <HBox spacing="6.0" styleClass="list-filter-group">
                     <padding>
                        <Insets bottom="4.0" left="8.0" right="8.0" top="4.0" />
                     </padding>
                     <children>
                        <Hyperlink fx:id="hlAll" alignment="CENTER" prefHeight="28.0" prefWidth="56.0" styleClass="filter-item" text="All" />
                        <Hyperlink fx:id="hlInPreview" alignment="CENTER" prefHeight="28.0" prefWidth="94.0" styleClass="filter-item" text="In preview" />
                     </children>
                  </HBox>
                  <Button fx:id="btnCreate" mnemonicParsing="false" prefHeight="33.0" prefWidth="94.0" styleClass="list-btn-create" text="Create" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                     <graphic>
                        <ImageView fitHeight="13.0" fitWidth="14.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../image/plus_white.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>

                  <Button fx:id="btnDelete" mnemonicParsing="false" prefHeight="33.0" prefWidth="94.0" styleClass="list-btn-delete" text="Delete" textFill="WHITE" />

                  <Region HBox.hgrow="ALWAYS" />
               </children>
            </HBox>

            <TableView id="taskListProject" fx:id="taskTable" prefHeight="200.0" prefWidth="843.0" styleClass="list-table" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colName" prefWidth="245.5" style="-fx-alignment: CENTER_LEFT;" text="Name" />
                  <TableColumn fx:id="colAssignee" prefWidth="100.5" style="-fx-alignment: CENTER_LEFT;" text="Assignee" />
                  <TableColumn fx:id="colStart" prefWidth="105.0" style="-fx-alignment: CENTER;" text="Start" />
                  <TableColumn fx:id="colDeadline" prefWidth="105.0" style="-fx-alignment: CENTER;" text="Deadline" />
                  <TableColumn fx:id="colStatus" prefWidth="112.0" style="-fx-alignment: CENTER;" text="Status" />
                  <TableColumn fx:id="colDescription" prefWidth="244.0" style="-fx-alignment: CENTER_LEFT;" text="Description" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
