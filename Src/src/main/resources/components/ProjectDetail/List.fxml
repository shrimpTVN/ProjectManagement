<AnchorPane prefHeight="400.0" prefWidth="549.6" stylesheets="@../../css/ListDetailProject.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.ListController">
