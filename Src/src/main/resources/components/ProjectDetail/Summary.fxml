<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="430.0" prefWidth="880.0" stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.SummaryController">
    <children>
        <HBox spacing="16.0" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="12.0">
            <children>
                <VBox prefWidth="430.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e4e4e4; -fx-border-radius: 12; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Project Completion" style="-fx-font-size: 18px; -fx-font-family: 'Urbanist Medium'; -fx-text-fill: #1f1f1f;" />
                        <Separator />
                        <PieChart fx:id="progressPieChart" labelsVisible="true" legendVisible="true" prefHeight="280.0" prefWidth="390.0" />
                        <Label fx:id="lblProgressPercent" text="0%" style="-fx-font-size: 28px; -fx-font-family: 'Urbanist SemiBold'; -fx-text-fill: #2f6ee5;" />
                        <Label fx:id="lblDoneOverTotal" text="0 / 0 tasks completed" style="-fx-font-size: 14px; -fx-font-family: 'Urbanist Regular'; -fx-text-fill: #555;" />
                    </children>
                </VBox>

                <VBox prefWidth="320.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e4e4e4; -fx-border-radius: 12; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Task Status Count" style="-fx-font-size: 18px; -fx-font-family: 'Urbanist Medium'; -fx-text-fill: #1f1f1f;" />
                        <Separator />
                        <VBox fx:id="statusStatsBox" spacing="8.0" VBox.vgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
