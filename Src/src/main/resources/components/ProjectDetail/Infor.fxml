<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="652.0" prefWidth="958.0" spacing="20" style="-fx-padding: 30; -fx-background-color: white;"
      stylesheets="@../../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.src.controllers.project.InforController">

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-background-color: white;">

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Description:"/>
                <Label fx:id="lblDescription" styleClass="font-14" text="Nội dung mô tả dự án sẽ hiển thị ở đây."
                       wrapText="true"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Start:"/>
                <Label fx:id="lblStartDate" styleClass="font-14" text="1/1/2026"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Deadline:"/>
                <Label fx:id="lblEndDate" styleClass="font-14" text="10/1/2026"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Members:"/>
                <Label fx:id="lblMemberCount" styleClass="font-14" text="2"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Admin:"/>
                <Label fx:id="lblAdminName" styleClass="font-14" text="Tên Admin"/>
            </VBox>

            <VBox prefHeight="122.0" prefWidth="896.0" spacing="5">
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Manager:"/>
                <Label fx:id="lblManagerName" prefHeight="34.0" prefWidth="436.0" styleClass="font-14"
                       text="Tên Manager" wrapText="true"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <HBox alignment="BOTTOM_RIGHT" spacing="10">
        <Button fx:id="btnEdit"
                style="-fx-background-color: white; -fx-border-color: black; -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand; -fx-pref-width: 120; -fx-pref-height: 30;"
                text="Edit"/>
        <Button fx:id="btnDelete"
                style="-fx-background-color: black; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand; -fx-pref-width: 120; -fx-pref-height: 30; -fx-font-weight: bold;"
                text="DELETE"/>
    </HBox>

</VBox>
