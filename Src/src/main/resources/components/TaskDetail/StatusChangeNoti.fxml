<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="statusChangeItemRoot" prefHeight="65.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.task.StatusHistoryController">
   <children>
      <VBox fx:id="mainLayout" spacing="8.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox fx:id="headerBox" alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Label fx:id="lblUser" style="-fx-font-weight: 700;" text="Oitloc96">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Label>
                  <Label fx:id="lblAction" text="changed the status" textFill="#555555">
                     <font>
                        <Font size="8.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" /> <Label fx:id="lblTime" alignment="CENTER_RIGHT" minWidth="100.0" text="8 phút trước" textFill="#888888">
                  <font>
                     <Font size="11.0" /> </font>
               </Label>
               </children>
            </HBox>
            <Label fx:id="lblStatusChange" text="In preview → Done">
               <font>
                  <Font size="13.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>

