<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="400.0" prefWidth="350.0" spacing="0.0"
      style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.src.controllers.task.CommentBoxController">
    <children>

        <ScrollPane fx:id="scrollChat" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: white;" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="vboxChatContent" spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" top="10.0"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" prefHeight="60.0" spacing="10.0"
              style="-fx-border-color: #eeeeee transparent transparent transparent;">
            <children>
                <TextField fx:id="txtMessage" prefHeight="35.0" promptText="Nhập nội dung thảo luận..."
                           style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #dddddd;"
                           HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnSend" mnemonicParsing="false" prefHeight="35.0" prefWidth="60.0"
                        style="-fx-background-color: #81c784; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: 700;"
                        text="Gửi">
                    <font>
                        <Font size="12.0"/>
                    </font>
                </Button>
            </children>
            <padding>
                <Insets left="10.0" right="10.0"/>
            </padding>
        </HBox>
    </children>
</VBox>
