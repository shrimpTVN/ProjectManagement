<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<HBox spacing="50" style="-fx-background-color: white; -fx-padding: 40;" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.src.controllers.task.CreateTaskController">

    <VBox maxWidth="500" spacing="10" HBox.hgrow="ALWAYS">
        <children>
            <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;" text="Create New Task"/>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="Task Name"/>
                <TextField fx:id="txtName" promptText="Enter task name..." style="-fx-pref-height: 35;"/>
                <Label fx:id="lblErrorName" style="-fx-text-fill: red; -fx-font-size: 12px;" text=""/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="Start Date"/>
                <DatePicker fx:id="dpStart" prefWidth="500" style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="End Date"/>
                <DatePicker fx:id="dpEnd" prefWidth="500" style="-fx-pref-height: 35;"/>
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="Assignee" />
                <ComboBox fx:id="cbAssignee" editable="true" prefWidth="500" style="-fx-pref-height: 35;" promptText="Nhập tên đăng nhập để tìm..." />
                <Label fx:id="lblErrorAssignee" style="-fx-text-fill: red; -fx-font-size: 12px;" text="" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;" styleClass="font-14" text="Description"/>
                <TextArea fx:id="txtDescription" prefRowCount="4" promptText="What needs to be done?" wrapText="true"/>
            </VBox>

            <HBox spacing="15" style="-fx-padding: 15 0 0 0;">
                <children>
                    <Button fx:id="btnCancel" onAction="#handleCancel" prefHeight="35.0" prefWidth="100.0"
                            style="-fx-background-color: #666666; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="× CANCEL"/>
                    <Button fx:id="btnSave" onAction="#handleSaveTask" prefHeight="35.0" prefWidth="100.0"
                            style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-text-fill: black; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="+ Create"/>
                </children>
            </HBox>
        </children>
    </VBox>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
        <StackPane prefHeight="300" prefWidth="400"
                   style="-fx-border-color: #cccccc; -fx-border-width: 2; -fx-background-color: #f9f9f9;">
            <children>
                <ImageView fitHeight="280" fitWidth="380" preserveRatio="true">
                    <image>
                        <Image url="@../image/task.png"/>
                    </image>
                </ImageView>
            </children>
        </StackPane>
    </VBox>

</HBox>
