<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="652.0" prefWidth="958.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER">
    <children>
        <Label fx:id="homeTitleLabel" text="Home" AnchorPane.leftAnchor="40.0" AnchorPane.topAnchor="30.0">
            <font>
                <Font name="Urbanist Regular" size="18.0" />
            </font>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
        </Label>

        <HBox alignment="CENTER" spacing="60.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button fx:id="allTasksBtn" mnemonicParsing="false" prefHeight="250.0" prefWidth="350.0" style="-fx-background-color: #7d7d7d; -fx-text-fill: white; -fx-alignment: top-left; -fx-padding: 20; -fx-background-radius: 5; -fx-border-color: black; -fx-border-radius: 5; -fx-border-width: 0.5;" text="All my tasks">
                    <font>
                        <Font name="Urbanist Regular" size="24.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>

                <Button fx:id="projectsBtn" mnemonicParsing="false" prefHeight="250.0" prefWidth="350.0" style="-fx-background-color: #7d7d7d; -fx-text-fill: white; -fx-alignment: top-left; -fx-padding: 20; -fx-background-radius: 5; -fx-border-color: black; -fx-border-radius: 5; -fx-border-width: 0.5;" text="According to the&#10;projects">
                    <font>
                        <Font name="Urbanist Regular" size="24.0" />
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </children>
        </HBox>
    </children>
</AnchorPane>
