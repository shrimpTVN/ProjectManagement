<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox style="-fx-background-color: white;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.project.ProjectDetailController">

    <VBox spacing="5" style="-fx-padding: 20 20 0 20;" styleClass="font-36">

        <Label fx:id="lblProjectName" styleClass="project-main-title" text="Project A">
            <VBox.margin>
                <Insets left="25.0" />
            </VBox.margin>
         <font>
            <Font name="Urbanist Medium" size="12.0" />
         </font>
        </Label>

        <HBox fx:id="projectDetailNavBar" spacing="36.0">
            <VBox.margin>
                <Insets left="35.0" right="35.0" top="11.0" />
            </VBox.margin>
            <Button fx:id="tabSummary" onMouseClicked="#handleNavbarClick" prefHeight="43.0" styleClass="project-detail-tab" text="Summary">
            <HBox.margin>
               <Insets left="15.0" />
            </HBox.margin></Button>
            <Button fx:id="tabList" onMouseClicked="#handleNavbarClick" prefHeight="43.0" styleClass="project-detail-tab" text="List" />
            <Button fx:id="tabBoard" onMouseClicked="#handleNavbarClick" prefHeight="43.0" styleClass="project-detail-tab" text="Board" />
            <Button fx:id="tabMember" onMouseClicked="#handleNavbarClick" prefHeight="43.0" styleClass="project-detail-tab" text="Member" />
            <Button fx:id="tabInfor" onMouseClicked="#handleNavbarClick" prefHeight="43.0" styleClass="project-detail-tab" text="Info" />
        </HBox>
      <Separator maxHeight="0.5" maxWidth="1.7976931348623157E308" minHeight="0.5" prefHeight="0.5" style="-fx-background-color: black;">
         <VBox.margin>
            <Insets left="35.0" right="35.0" />
         </VBox.margin>
      </Separator>
    </VBox>

    <StackPane fx:id="tabContentArea" style="-fx-padding: 20;" VBox.vgrow="ALWAYS" />

</VBox>
