<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="authContainer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.LoginController">
    <center>
        <AnchorPane prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" BorderPane.alignment="CENTER">
            <children>
                <!--            control button-->
                <Button fx:id="loginBtn" layoutX="489.0" layoutY="474.0" mnemonicParsing="false"
                        onAction="#handleLoginBtnClick" prefHeight="35.0" prefWidth="308.0"
                        style="-fx-background-color: #4896FE; -fx-border-radius: 10; -fx-background-radius: 10;"
                        text="Login" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Button>
                <Button fx:id="cancelBtn" layoutX="490.0" layoutY="524.0" mnemonicParsing="false"
                        onAction="#handleCancelBtnClick" prefHeight="35.0" prefWidth="308.0"
                        style="-fx-background-color: #FFFFFF; -fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"
                        text="Cancel" textFill="#4896fe">
                    <font>
                        <Font name="Urbanist Medium" size="16.0"/>
                    </font>
                </Button>
                <Label alignment="CENTER" layoutX="670.0" layoutY="220.0" onMouseClicked="#goToSignUp" prefHeight="18.0"
                       prefWidth="95.0" text="Sign up now" textAlignment="CENTER" textFill="#4896fe">
                    <font>
                        <Font name="Urbanist Medium" size="14.0"/>
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Label>
                <Label layoutX="524.0" layoutY="220.0" text="Don't have an account ?">
                    <font>
                        <Font name="Urbanist Medium" size="14.0"/>
                    </font>
                </Label>
                <Label layoutX="501.0" layoutY="351.0" text="Password: ">
                    <font>
                        <Font name="Urbanist Bold" size="14.0"/>
                    </font>
                </Label>
                <TextField fx:id="userNameInput" layoutX="490.0" layoutY="303.0" prefHeight="35.0" prefWidth="308.0"
                           promptText="Username"
                           style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;">
                </TextField>
                <Label layoutX="500.0" layoutY="283.0" text="Username: ">
                    <font>
                        <Font name="Urbanist Bold" size="14.0"/>
                    </font>
                </Label>
                <PasswordField fx:id="passwordInput" layoutX="490.0" layoutY="369.0" prefHeight="35.0" prefWidth="308.0"
                               promptText="Password"
                               style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;">
                    <font>
                        <Font name="Urbanist Medium" size="13.0"/>
                    </font>
                </PasswordField>
                <ImageView fitHeight="123.0" fitWidth="136.0" layoutX="579.0" layoutY="63.0" pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../image/Frame%20115.png"/>
                    </image>
                </ImageView>

            </children>
        </AnchorPane>
    </center>
</BorderPane>
