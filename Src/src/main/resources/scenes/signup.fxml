<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0"
            prefWidth="1280.0" style="-fx-background-color: #f8f8f8;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.app.src.controllers.SignUpController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <ImageView fitHeight="77.0" fitWidth="82.0" layoutX="579.0" layoutY="63.0" pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@../image/Frame%20115.png"/>
                    </image>
                </ImageView>
                <Label alignment="CENTER" onMouseClicked="#goToLogin" text="You have an account ? Login now"
                       textFill="#4896fe">
                    <font>
                        <Font name="System" size="14.0"/>
                    </font>
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                </Label>

                <VBox maxWidth="320.0" spacing="4.0">
                    <children>
                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Username"/>
                        <TextField fx:id="usernameInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                   style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Name"/>
                        <TextField fx:id="nameInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                   style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Telephone"/>
                        <TextField fx:id="phoneInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                   style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Date of Birth"/>
                        <DatePicker fx:id="dobInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                    style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label maxWidth="1.7976931348623157E308" prefHeight="13.0" prefWidth="320.0"
                               style="-fx-font-family: 'System Bold';" styleClass="font-14" text="Sex"/>
                        <HBox alignment="CENTER" spacing="30.0">
                            <children>
                                <RadioButton mnemonicParsing="false" style="-fx-font-family: 'System Bold';"
                                             styleClass="font-14" text="Male">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="gender"/>
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton mnemonicParsing="false" style="-fx-font-family: 'System Bold';"
                                             styleClass="font-14" text="Female" toggleGroup="$gender"/>
                            </children>
                            <VBox.margin>
                                <Insets bottom="5.0" top="5.0"/>
                            </VBox.margin>
                        </HBox>

                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Password"/>
                        <PasswordField fx:id="passwordInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                       style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label maxWidth="1.7976931348623157E308" style="-fx-font-family: 'System Bold';"
                               styleClass="font-14" text="Password again"/>
                        <PasswordField fx:id="passwordAgainInput" maxWidth="1.7976931348623157E308" prefHeight="35.0"
                                       style="-fx-border-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"/>

                        <Label fx:id="labelMess" alignment="CENTER" maxWidth="1.7976931348623157E308"
                               styleClass="font-14" text="" wrapText="true"/>

                        <Button fx:id="signUpBtn" alignment="CENTER" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" onAction="#handleSignUp" prefHeight="35.0"
                                style="-fx-background-color: #4896FE; -fx-background-radius: 10; -fx-border-radius: 10;"
                                text="SIGN UP" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0"/>
                            </font>
                            <VBox.margin>
                                <Insets top="5.0"/>
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>



